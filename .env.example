# Copy to .env and fill in. All optional in dev; set the secrets in production.

# Server
PORT=3000
DATA_DIR=./data

# Auth (shared-password). Leave APP_PASSWORD empty in dev to skip login.
APP_PASSWORD=
SESSION_SECRET=change-me-to-a-long-random-string

# Claude chat (optional)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# Web Push — VAPID keypair is auto-generated into the DB on first run; set the contact only.
VAPID_SUBJECT=mailto:you@example.com

# Receipt/email inbox (optional). Set a long random token to enable /api/inbox/:token.
INBOX_TOKEN=
